{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch DoomHub Dev",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"],
      "serverReadyAction": {
        "pattern": "Local:\\s+(http://localhost:5173/?)",
        "uriFormat": "%s",
        "action": "openExternally"
      }
    }
  ]
}
