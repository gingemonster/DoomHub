PUBLIC_BASE_URL=http://localhost:5173
IPX_WSS_URL=wss://netherlands.dos.zone
ROOM_TTL_MINUTES=180
WAD_STORAGE_PATH=./data/wads
BUNDLE_STORAGE_PATH=./data/bundles
DATABASE_PATH=./data/doomhub.sqlite
PORT=3000

# Docker Compose proxy mode:
# - Leave COMPOSE_PROFILES empty to expose web on :3000 and IPX on :9001.
# - Set COMPOSE_PROFILES=managed-proxy to also start bundled Caddy on PUBLIC_HTTP_PORT.
# - For external proxies such as Nginx Proxy Manager, keep this empty and point the proxy
#   at web:3000 plus ipx:9001 if it runs in the same Docker network, or localhost ports
#   from the host.
COMPOSE_PROFILES=
PUBLIC_HTTP_PORT=8080
