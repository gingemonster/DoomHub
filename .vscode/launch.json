{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch DoomHub Dev",
      "type": "node-terminal",
      "request": "launch",
      "command": "npm run dev",
      "cwd": "${workspaceFolder}",
      "serverReadyAction": {
        "pattern": "Local:\\s+(http://localhost:5173/?)",
        "uriFormat": "%s",
        "action": "openExternally"
      }
    }
  ]
}
